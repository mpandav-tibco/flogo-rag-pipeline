                    "fe_metadata": "{\"type\":\"object\",\"properties\":{\"files\":{\"type\":\"object\",\"properties\":{\"content\":{\"type\":\"any\"},\"filename\":{\"type\":\"string\"},\"content-type\":{\"type\":\"string\"}}},\"chunking_strategy\":{\"type\":\"string\"},\"max_characters\":{\"type\":\"string\"}}}"
