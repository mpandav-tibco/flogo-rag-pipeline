{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/mpandav-tibco/flogo-extensions/vectordb/activity/createCollection",
    "github.com/mpandav-tibco/flogo-extensions/vectordb/activity/ingestDocuments",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/mpandav-tibco/flogo-extensions/vectordb/activity/ragQuery",
    "github.com/tibco/flogo-general/src/app/General/activity/rest",
    "rest_1 github.com/tibco/flogo-general/src/app/General/trigger/rest",
    "github.com/project-flogo/contrib/function/coerce",
    "github.com/project-flogo/contrib/function/string",
    "github.com/project-flogo/contrib/function/array",
    "github.com/mpandav-tibco/flogo-extensions/vectordb/connector"
  ],
  "name": "weaviate-rag-mcp",
  "description": "RAG service for Weaviate — exposes document ingest and semantic query as REST endpoints and MCP tools. Embeddings via Ollama nomic-embed-text, storage and retrieval via Weaviate vector database.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#rest_1",
      "name": "tibco-wi-rest",
      "description": "REST trigger exposing /rag/weaviate/ingest and /rag/weaviate/query endpoints on port 9191",
      "settings": {
        "port": 9191,
        "APISpecUpdate": false,
        "swagger": "",
        "swaggerVersion": "v2",
        "authenticationType": "None",
        "username": "",
        "password": "",
        "apiVersion": "1.0.0",
        "secureConnection": false,
        "serverKey": "",
        "caCertificate": ""
      },
      "id": "RAGRestTrigger",
      "handlers": [
        {
          "description": "Accept documents via POST body or MCP arguments, embed with Ollama, create collection and ingest into Weaviate (collection name must be PascalCase)",
          "settings": {
            "APISpecPath": "",
            "Method": "POST",
            "reqType": "application/json",
            "Path": "/rag/weaviate/ingest",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:weaviate_ingest"
            },
            "input": {
              "body": "=$.body",
              "headers": "=$.headers"
            },
            "output": {
              "data": "=$.data",
              "code": "=$.code"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": {}
          },
          "schemas": {
            "reply": {
              "data": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{}}",
                "fe_metadata": "{}"
              },
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              },
              "body": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"collection\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}},\"documents\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"items\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"properties\":{\"type\":\"object\",\"properties\":{\"id\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}},\"text\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}}}}}}}}}}",
                "fe_metadata": "{\"collection\":{\"type\":\"string\"},\"documents\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"id\":{\"type\":\"string\"},\"text\":{\"type\":\"string\"}}}}}"
              }
            }
          },
          "name": "weaviate_ingest"
        },
        {
          "description": "Accept natural language query from REST body or MCP arguments, embed with Ollama, retrieve top-K context passages from Weaviate",
          "settings": {
            "APISpecPath": "",
            "Method": "POST",
            "reqType": "application/json",
            "Path": "/rag/weaviate/query",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:weaviate_query"
            },
            "input": {
              "body": "=$.body",
              "headers": "=$.headers"
            },
            "output": {
              "code": "=$.code",
              "data": "=$.data"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": {}
          },
          "schemas": {
            "reply": {
              "data": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{}}",
                "fe_metadata": "{}"
              },
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              },
              "body": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"collection\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}},\"query\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}},\"topK\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}}}}",
                "fe_metadata": "{\"collection\":{\"type\":\"string\"},\"query\":{\"type\":\"string\"},\"topK\":{\"type\":\"number\"}}"
              }
            }
          },
          "name": "weaviate_query"
        },
        {
          "description": "Receive a binary file upload via multipart/form-data, extract text (PDF/DOCX/TXT), embed with Ollama and ingest into Weaviate.",
          "settings": {
            "APISpecPath": "",
            "Method": "POST",
            "reqType": "multipart/form-data",
            "Path": "/rag/weaviate/ingest/upload",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:weaviate_ingest_upload"
            },
            "input": {
              "multipartFormData": "=$.multipartFormData",
              "headers": "=$.headers"
            },
            "output": {
              "data": "=$.data",
              "code": "=$.code"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": {}
          },
          "schemas": {
            "reply": {
              "data": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{}}",
                "fe_metadata": "{}"
              },
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Content-Type\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              },
              "multipartFormData": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"collection\":{\"type\":\"string\"},\"filename\":{\"type\":\"string\"},\"file\":{\"type\":\"any\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"collection\":{\"type\":\"string\"},\"filename\":{\"type\":\"string\"},\"file\":{\"type\":\"any\"}}}"
              },
              "multipartForm": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"},\"type\":{\"type\":\"string\"},\"required\":{\"type\":\"string\"},\"schema\":{\"type\":\"string\"}},\"required\":[\"name\",\"type\",\"required\"]}}",
                "fe_metadata": "[{\"name\":\"collection\",\"type\":\"string\",\"required\":\"true\"},{\"name\":\"filename\",\"type\":\"string\",\"required\":\"false\"},{\"name\":\"file\",\"type\":\"filecontent\",\"required\":\"true\",\"schema\":\"\"}]"
              }
            }
          },
          "name": "weaviate_ingest_upload"
        },
        {
          "description": "Full RAG with LLM generation: embed + hybrid search + llama3.1:8b answer",
          "settings": {
            "APISpecPath": "",
            "Method": "POST",
            "reqType": "application/json",
            "Path": "/rag/weaviate/query/generate",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:weaviate_query_generate"
            },
            "input": {
              "body": "=$.body",
              "headers": "=$.headers"
            },
            "output": {
              "code": "=$.code",
              "data": "=$.data"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": {}
          },
          "schemas": {
            "reply": {
              "data": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{}}",
                "fe_metadata": "{}"
              },
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              },
              "body": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"collection\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}},\"query\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}},\"topK\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}}}}",
                "fe_metadata": "{\"collection\":{\"type\":\"string\"},\"query\":{\"type\":\"string\"},\"topK\":{\"type\":\"number\"}}"
              }
            }
          },
          "name": "weaviate_query_generate"
        },
        {
          "description": "Smart ingest: Docling extracts structured Markdown (preserves tables/headings), heading-strategy chunker splits on ##, every chunk inherits global metadata (interface_id, owner, document_type, source_file).",
          "settings": {
            "APISpecPath": "",
            "Method": "POST",
            "reqType": "multipart/form-data",
            "Path": "/rag/weaviate/ingest/smart",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:weaviate_ingest_smart"
            },
            "input": {
              "multipartFormData": "=$.multipartFormData",
              "headers": "=$.headers"
            },
            "output": {
              "data": "=$.data",
              "code": "=$.code"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": ""
          },
          "schemas": {
            "reply": {
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Content-Type\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              },
              "multipartFormData": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"collection\":{\"type\":\"string\"},\"filename\":{\"type\":\"string\"},\"file\":{\"type\":\"any\"},\"interface_id\":{\"type\":\"string\"},\"owner\":{\"type\":\"string\"},\"document_type\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"collection\":{\"type\":\"string\"},\"filename\":{\"type\":\"string\"},\"file\":{\"type\":\"any\"},\"interface_id\":{\"type\":\"string\"},\"owner\":{\"type\":\"string\"},\"document_type\":{\"type\":\"string\"}}}"
              },
              "multipartForm": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"},\"type\":{\"type\":\"string\"},\"required\":{\"type\":\"string\"},\"schema\":{\"type\":\"string\"}},\"required\":[\"name\",\"type\",\"required\"]}}",
                "fe_metadata": "[{\"name\":\"collection\",\"type\":\"string\",\"required\":\"true\"},{\"name\":\"filename\",\"type\":\"string\",\"required\":\"false\"},{\"name\":\"file\",\"type\":\"filecontent\",\"required\":\"true\",\"schema\":\"\"},{\"name\":\"interface_id\",\"type\":\"string\",\"required\":\"false\"},{\"name\":\"owner\",\"type\":\"string\",\"required\":\"false\"},{\"name\":\"document_type\",\"type\":\"string\",\"required\":\"false\"}]"
              }
            }
          },
          "name": "weaviate_ingest_smart"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:weaviate_ingest",
      "data": {
        "name": "weaviate_ingest",
        "description": "Accept documents via POST body or MCP arguments, embed with Ollama, create collection and ingest into Weaviate (collection name must be PascalCase)",
        "links": [
          {
            "id": 1,
            "from": "Start",
            "to": "LogRequest",
            "type": "label",
            "label": "start"
          },
          {
            "id": 2,
            "from": "LogRequest",
            "to": "CreateCollection",
            "type": "label",
            "label": "log"
          },
          {
            "id": 3,
            "from": "CreateCollection",
            "to": "IngestDocs",
            "type": "label",
            "label": "created"
          },
          {
            "id": 4,
            "from": "IngestDocs",
            "to": "LogResult",
            "type": "label",
            "label": "ingested"
          },
          {
            "id": 5,
            "from": "LogResult",
            "to": "Return",
            "type": "label",
            "label": "done"
          }
        ],
        "tasks": [
          {
            "id": "Start",
            "name": "Start",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "LogRequest",
            "name": "LogRequest",
            "description": "Simple Log Message Activity",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[weaviate-rag-mcp] Ingest request: collection=', coerce.toString($flow.body.collection), ' docCount=', coerce.toString($flow.body.documents))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "CreateCollection",
            "name": "CreateCollection",
            "description": "Create RAG collection in Weaviate (768-dim cosine, PascalCase name required). Succeeds silently if already exists.",
            "activity": {
              "ref": "#createCollection",
              "settings": {
                "connection": "conn://weaviate-conn"
              },
              "input": {
                "collectionName": "=$flow.body.collection",
                "dimensions": 768,
                "distanceMetric": "cosine",
                "onDisk": false,
                "replicationFactor": 1
              }
            }
          },
          {
            "id": "IngestDocs",
            "name": "IngestDocs",
            "description": "Embed documents with Ollama nomic-embed-text and upsert into Weaviate via VectorDB connector",
            "activity": {
              "ref": "#ingestDocuments",
              "settings": {
                "connection": "conn://weaviate-conn",
                "enableChunking": true,
                "chunkStrategy": "paragraph",
                "chunkSize": 2000,
                "chunkOverlap": 200,
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "defaultCollection": "",
                "contentField": "text",
                "timeoutSeconds": 120,
                "embeddingBatchSize": 10
              },
              "input": {
                "collectionName": "=$flow.body.collection",
                "fileName": "",
                "documents": "=$flow.body.documents"
              }
            }
          },
          {
            "id": "LogResult",
            "name": "LogResult",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[weaviate-rag-mcp] Ingest COMPLETE collection=', coerce.toString($flow.body.collection), ' ingested=', coerce.toString($activity[IngestDocs].ingestedCount), ' dims=', coerce.toString($activity[IngestDocs].dimensions), ' duration=', $activity[IngestDocs].duration)",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "code": 200,
                  "data": "=$activity[IngestDocs]"
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydCI6eyJ4Ijo1MCwieSI6NTB9LCJMb2dSZXF1ZXN0Ijp7IngiOjE5NCwieSI6NDh9LCJDcmVhdGVDb2xsZWN0aW9uIjp7IngiOjQyNCwieSI6NTB9LCJJbmdlc3REb2NzIjp7IngiOjYxNSwieSI6NDl9LCJMb2dSZXN1bHQiOnsieCI6ODI1LCJ5Ijo1M30sIlJldHVybiI6eyJ4IjoxMDMzLCJ5Ijo0N319",
        "metadata": {
          "input": [
            {
              "name": "headers",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}}"
              }
            },
            {
              "name": "body",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"collection\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}},\"documents\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"items\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"properties\":{\"type\":\"object\",\"properties\":{\"id\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}},\"text\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}}}}}}}}}"
