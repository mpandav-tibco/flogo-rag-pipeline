              "settings": {
                "connection": "conn://weaviate-conn"
              },
              "input": {
                "collectionName": "=$flow.multipartFormData.collection",
                "dimensions": 768,
                "distanceMetric": "cosine",
                "onDisk": false,
                "replicationFactor": 1
              }
            }
          },
