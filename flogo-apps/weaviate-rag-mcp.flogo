    {
      "id": "flow:weaviate_ingest_upload",
      "data": {
        "name": "weaviate_ingest_upload",
        "description": "Receive a binary file upload via multipart/form-data, extract text (PDF/DOCX/TXT), embed with Ollama and ingest into Weaviate.",
        "links": [
          {
            "id": 1,
            "from": "Start",
            "to": "LogUpload",
            "type": "label",
            "label": "start"
          },
          {
            "id": 2,
            "from": "LogUpload",
            "to": "CreateCollection",
            "type": "label",
            "label": "log"
          },
          {
            "id": 3,
            "from": "CreateCollection",
            "to": "UnstructuredExtract",
            "type": "label",
            "label": "created"
          },
          {
            "id": 4,
            "from": "UnstructuredExtract",
            "to": "IngestFile",
            "type": "label",
            "label": "extracted"
          },
          {
            "id": 5,
            "from": "IngestFile",
            "to": "LogResult",
            "type": "label",
            "label": "ingested"
          },
          {
            "id": 6,
            "from": "LogResult",
            "to": "Return",
            "type": "label",
            "label": "done"
          }
        ],
        "tasks": [
          {
            "id": "Start",
            "name": "Start",
            "description": "",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "LogUpload",
            "name": "LogUpload",
            "description": "",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[weaviate-rag-mcp] File upload: collection=', coerce.toString($flow.multipartFormData.collection), ' filename=', coerce.toString($flow.multipartFormData.filename))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "CreateCollection",
            "name": "CreateCollection",
            "description": "Create RAG collection (no-op if already exists via error link).",
            "activity": {
              "ref": "#createCollection",
              "settings": {
                "connection": "conn://weaviate-conn"
              },
              "input": {
                "collectionName": "=$flow.multipartFormData.collection",
                "dimensions": 768,
                "distanceMetric": "cosine",
                "onDisk": false,
                "replicationFactor": 1
              }
            }
          },
          {
            "id": "UnstructuredExtract",
            "name": "UnstructuredExtract",
            "description": "Call Docling API to extract and chunk text from uploaded PDF/DOCX. POST multipart to /general/v0/general, returns {text, filename} JSON.",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#rest",
              "input": {
                "enableASR": false,
                "swagger": "",
                "authorization": false,
                "serviceName": "",
                "resourcePath": "",
                "Method": "POST",
                "Uri": "=$property[\"DOCLING_BASE_URL\"]",
                "requestType": "multipart/form-data",
                "Use certificate for verification": false,
                "mutualAuth": false,
                "Client Certificate": "",
                "Client Key": "",
                "Server Certificate": "",
                "disableSSLVerification": false,
                "disableKeepAlives": false,
                "followRedirects": true,
                "Timeout": 1900000,
                "proxy": "",
                "host": "",
                "serviceUrl": "",
                "multipartForm": {
                  "metadata": "",
                  "value": "[{\"name\":\"files\",\"type\":\"file\",\"required\":\"\",\"schema\":\"\"},{\"name\":\"chunking_strategy\",\"type\":\"string\",\"required\":\"\",\"schema\":\"\"},{\"name\":\"max_characters\",\"type\":\"string\",\"required\":\"\",\"schema\":\"\"}]"
                },
                "headers": {
                  "mapping": {
                    "Accept": "application/json"
                  }
                },
                "dynamicRequestHeaders": {
                  "mapping": {}
                },
                "multipartFormData": {
                  "mapping": {
                    "files": {
                      "filename": "=$flow.multipartFormData.filename",
                      "content": "=$flow.multipartFormData.file"
                    },
                    "chunking_strategy": "by_title",
                    "max_characters": "50000"
                  }
                }
              },
              "output": {
                "configureResponseCodes": false,
                "throwError": false,
                "responseType": "application/json",
                "responseOutput": "JSON"
              },
              "schemas": {
                "input": {
                  "headers": {
                    "type": "json",
                    "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                    "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}, {\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
