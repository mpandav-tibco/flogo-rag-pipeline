                  "multipartForm": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"},\"type\":{\"type\":\"string\"},\"required\":{\"type\":\"string\"},\"schema\":{\"type\":\"string\"}}}}",
                    "fe_metadata": "[{\"name\":\"files\",\"type\":\"file\",\"required\":\"\",\"schema\":\"\"}]"
                  }
                },
                "output": {
                  "responseBody": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-07/schema#\",\"type\":\"object\",\"properties\":{\"markdown\":{\"type\":\"string\"},\"filename\":{\"type\":\"string\"}}}",
                    "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-07/schema#\",\"type\":\"object\",\"properties\":{\"markdown\":{\"type\":\"string\"},\"filename\":{\"type\":\"string\"}}}"
                  },
                  "headers": {
                    "type": "json",
                    "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false},\"Set-Cookie\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                    "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Set-Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "IngestDocs",
            "name": "IngestDocs",
            "description": "Build documents[] with global metadata, chunk Markdown by ## heading, embed via Ollama, upsert to Weaviate.",
            "activity": {
              "ref": "#ingestDocuments",
              "settings": {
                "connection": "conn://weaviate-conn",
                "enableChunking": true,
                "chunkStrategy": "heading",
                "chunkSize": 4000,
                "chunkOverlap": 0,
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "defaultCollection": "",
                "contentField": "text",
                "timeoutSeconds": 120,
                "embeddingBatchSize": 10
              },
              "input": {
                "collectionName": "=$flow.multipartFormData.collection",
                "fileName": "",
                "documents": {
                  "mapping": [
                    {
                      "id": "=$flow.multipartFormData.filename",
                      "text": "=$activity[DoclingMarkdown].responseBody.markdown",
                      "metadata": {
                        "interface_id": "=$flow.multipartFormData.interface_id",
                        "owner": "=$flow.multipartFormData.owner",
                        "source_file": "=$flow.multipartFormData.filename",
                        "document_type": "=$flow.multipartFormData.document_type"
                      }
                    }
                  ]
                },
                "fileContent": ""
              }
            }
          },
          {
            "id": "LogResult",
            "name": "LogResult",
            "description": "Log smart-ingest result.",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[weaviate-rag-mcp] SMART COMPLETE collection=', coerce.toString($flow.multipartFormData.collection), ' file=', coerce.toString($flow.multipartFormData.filename), ' chunks=', coerce.toString($activity[IngestDocs].ingestedCount), ' duration=', $activity[IngestDocs].duration)",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Return structured response: status, file, chunks_embedded, processing_time.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "code": 200,
                  "data": {
                    "mapping": {
                      "status": "success",
                      "file": "=$flow.multipartFormData.filename",
                      "collection": "=$flow.multipartFormData.collection",
                      "chunks_embedded": "=$activity[IngestDocs].ingestedCount",
                      "processing_time": "=$activity[IngestDocs].duration",
                      "metadata": {
                        "interface_id": "=$flow.multipartFormData.interface_id",
                        "owner": "=$flow.multipartFormData.owner",
                        "document_type": "=$flow.multipartFormData.document_type"
                      }
                    }
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydCI6eyJ4Ijo1MCwieSI6NTB9LCJMb2dVcGxvYWQiOnsieCI6MjUwLCJ5IjoxNTB9LCJDcmVhdGVDb2xsZWN0aW9uIjp7IngiOjQ1MCwieSI6MjUwfSwiRG9jbGluZ01hcmtkb3duIjp7IngiOjY1MCwieSI6MzUwfSwiSW5nZXN0RG9jcyI6eyJ4Ijo4NTAsInkiOjQ1MH0sIkxvZ1Jlc3VsdCI6eyJ4IjoxMDUwLCJ5Ijo1NTB9LCJSZXR1cm4iOnsieCI6MTI1MCwieSI6NjUwfX0=",
        "metadata": {
          "input": [
            {
              "name": "headers",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"Content-Type\":{\"type\":\"string\",\"visible\":false}}"
              }
            },
            {
              "name": "multipartFormData",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"collection\":{\"type\":\"string\"},\"filename\":{\"type\":\"string\"},\"file\":{\"type\":\"any\"},\"interface_id\":{\"type\":\"string\"},\"owner\":{\"type\":\"string\"},\"document_type\":{\"type\":\"string\"}}"
              }
            },
            {
              "name": "requestURI",
              "type": "string"
            },
            {
