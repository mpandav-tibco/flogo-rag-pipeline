            "from": "CreateCollection",
            "to": "DoclingMarkdown",
            "type": "label",
            "label": "CreateCollection to DoclingMarkdown"
          },
          {
            "id": 4,
            "from": "DoclingMarkdown",
            "to": "IngestDocs",
            "type": "label",
            "label": "DoclingMarkdown to IngestDocs"
          },
          {
            "id": 5,
            "from": "IngestDocs",
            "to": "LogResult",
            "type": "label",
            "label": "IngestDocs to LogResult"
          },
          {
            "id": 6,
            "from": "LogResult",
            "to": "Return",
            "type": "label",
            "label": "LogResult to Return"
          }
        ],
