          {
            "id": "IngestFile",
            "name": "IngestFile",
            "description": "Extract text from uploaded file (PDF/DOCX/TXT) and ingest into VectorDB.",
            "activity": {
              "ref": "#ingestDocuments",
              "settings": {
                "connection": "conn://weaviate-conn",
                "enableChunking": true,
                "chunkStrategy": "heading",
                "chunkSize": 4000,
                "chunkOverlap": 0,
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "defaultCollection": "",
                "contentField": "text",
                "timeoutSeconds": 120,
                "embeddingBatchSize": 10
              },
              "input": {
                "collectionName": "=$flow.multipartFormData.collection",
                "fileName": "=string.concat($activity[UnstructuredExtract].responseBody.filename, \".txt\")",
                "documents": {
                  "mapping": []
                },
                "fileContent": "=$activity[UnstructuredExtract].responseBody.text"
              }
            }
          },
          {
            "id": "LogResult",
            "name": "LogResult",
            "description": "Log ingest result",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[weaviate-rag-mcp] Upload COMPLETE collection=', coerce.toString($flow.multipartFormData.collection), ' file=', coerce.toString($flow.multipartFormData.filename), ' ingested=', coerce.toString($activity[IngestFile].ingestedCount), ' duration=', $activity[IngestFile].duration)",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "code": 200,
                  "data": "=$activity[IngestFile]"
                }
              }
            }
          }
        ],
