                "flowInfo": false,
                "message": "=string.concat('[weaviate-rag-mcp] SMART upload collection=', coerce.toString($flow.multipartFormData.collection), ' file=', coerce.toString($flow.multipartFormData.filename), ' interface_id=', coerce.toString($flow.multipartFormData.interface_id), ' owner=', coerce.toString($flow.multipartFormData.owner), ' doc_type=', coerce.toString($flow.multipartFormData.document_type))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "CreateCollection",
            "name": "CreateCollection",
            "description": "Create RAG collection (no-op if already exists via error link).",
