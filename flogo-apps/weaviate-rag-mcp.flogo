              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat('[weaviate-rag-mcp] Query request: collection=', coerce.toString($flow.body.collection), ' query=', coerce.toString($flow.body.query), ' topK=', coerce.toString($flow.body.topK))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "RAGQueryGenerate",
            "name": "RAGQueryGenerate",
            "description": "Embed + hybrid search + LLM answer generation",
            "activity": {
              "ref": "#ragQuery",
              "settings": {
                "connection": "conn://weaviate-conn",
                "useConnectorEmbedding": false,
                "embeddingProvider": "=$property[\"EMBED_PROVIDER\"]",
                "embeddingAPIKey": "=$property[\"EMBED_API_KEY\"]",
                "embeddingBaseURL": "=$property[\"EMBED_BASE_URL\"]",
                "embeddingModel": "=$property[\"EMBED_MODEL\"]",
                "embeddingDimensions": 0,
                "defaultCollection": "",
                "defaultTopK": 3,
                "scoreThreshold": 0,
                "contentField": "text",
                "contextFormat": "markdown",
                "timeoutSeconds": 300,
                "useHybridSearch": true,
                "hybridAlpha": 0.75,
                "enableLLMGenerate": true,
                "llmProvider": "=$property[\"LLM_PROVIDER\"]",
                "llmBaseURL": "=$property[\"LLM_BASE_URL\"]",
                "llmAPIKey": "",
                "llmModel": "=$property[\"LLM_MODEL\"]",
                "systemPrompt": "You are a precise fact-extraction assistant. The context contains Markdown tables and structured data. Look carefully through ALL table rows and columns to find the answer. Return ONLY the exact value from the context — no explanation, no hedging. If you truly cannot find the answer anywhere in the context, reply exactly: NOT_FOUND",
                "maxTokens": 1024,
                "temperature": 0.1
              },
              "input": {
                "queryText": "=$flow.body.query",
                "collectionName": "=$flow.body.collection",
                "topK": "=$flow.body.topK",
                "systemPrompt": ""
              }
            }
          },
          {
            "id": "SendRagevalEvent",
            "name": "SendRagevalEvent",
            "description": "POST rageval evaluation event to the rageval service — non-blocking, returns 202. Sends query, retrieved chunks and formatted context for quality scoring.",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
