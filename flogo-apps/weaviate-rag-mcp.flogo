  "schemas": {
    "RagevalEventBody": {
      "type": "json",
      "value": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"pipelineId\": {\n      \"type\": \"string\"\n    },\n    \"platform\": {\n      \"type\": \"string\"\n    },\n    \"traceId\": {\n      \"type\": \"string\"\n    },\n    \"collection\": {\n      \"type\": \"string\"\n    },\n    \"query\": {\n      \"type\": \"string\"\n    },\n    \"chunks\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"id\": {\n            \"type\": \"string\"\n          },\n          \"text\": {\n            \"type\": \"string\"\n          },\n          \"score\": {\n            \"type\": \"number\"\n          }\n        }\n      }\n    },\n    \"answer\": {\n      \"type\": \"string\"\n    }\n  }\n}",
      "fe_metadata": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"pipelineId\": {\n      \"type\": \"string\"\n    },\n    \"platform\": {\n      \"type\": \"string\"\n    },\n    \"traceId\": {\n      \"type\": \"string\"\n    },\n    \"collection\": {\n      \"type\": \"string\"\n    },\n    \"query\": {\n      \"type\": \"string\"\n    },\n    \"chunks\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"id\": {\n            \"type\": \"string\"\n          },\n          \"text\": {\n            \"type\": \"string\"\n          },\n          \"score\": {\n            \"type\": \"number\"\n          }\n        }\n      }\n    },\n    \"answer\": {\n      \"type\": \"string\"\n    }\n  }\n}"
    }
  },
  "connections": {
    "weaviate-conn": {
      "id": "weaviate-conn",
      "name": "WeaviateConn",
      "ref": "#connector",
      "isGlobal": false,
      "settings": {
        "name": "=$property[\"VectorDB.WeaviateConn.Connection_Name\"]",
        "dbType": "=$property[\"VectorDB.WeaviateConn.DB_Provider\"]",
        "host": "=$property[\"VectorDB.WeaviateConn.Host\"]",
        "port": "=$property[\"VectorDB.WeaviateConn.Port\"]",
        "apiKey": "=$property[\"VectorDB.WeaviateConn.API_Key\"]",
        "useTLS": "=$property[\"VectorDB.WeaviateConn.Secure_Connection\"]",
        "tlsInsecureSkipVerify": false,
        "timeoutSeconds": "=$property[\"VectorDB.WeaviateConn.Timeout_(seconds)\"]",
        "maxRetries": "=$property[\"VectorDB.WeaviateConn.Max_Retries\"]",
        "retryBackoffMs": "=$property[\"VectorDB.WeaviateConn.Retry_Backoff_(ms)\"]",
        "grpcPort": 0,
        "scheme": "=$property[\"VectorDB.WeaviateConn.HTTP_Scheme\"]",
        "dbName": "default",
        "defaultMetricType": "cosine",
        "enableEmbedding": "=$property[\"VectorDB.WeaviateConn.Configure_Embedding_Provider\"]",
        "embeddingProvider": "OpenAI"
      }
    }
  },
  "contrib": "",
  "metadata": {
    "endpoints": [
      {
        "protocol": "http",
        "port": "9191",
        "spec": {
          "name": "weaviate-rag-mcp",
          "version": "1.0.0"
        },
        "title": "RAGRestTrigger",
        "swagger": {
          "swagger": "2.0",
          "info": {
            "title": "weaviate-rag-mcp",
            "version": "1.0.0",
            "description": "REST trigger exposing /rag/weaviate/ingest and /rag/weaviate/query endpoints on port 9191"
          },
          "paths": {
            "/rag/weaviate/ingest": {
              "post": {
                "summary": "weaviate_ingest",
                "operationId": "post_rag_weaviate_ingest",
                "parameters": [
                  {
                    "name": "Authorization",
                    "in": "header",
                    "description": "Request parameter",
                    "required": false,
                    "type": "string"
                  },
                  {
                    "name": "body",
                    "in": "body",
                    "description": "request body parameter",
                    "required": true,
                    "schema": {
                      "$ref": "#/definitions/schema1"
                    }
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Rest Response",
                    "schema": {
                      "$ref": "#/definitions/schema2"
                    }
                  }
                },
                "description": "Accept documents via POST body or MCP arguments, embed with Ollama, create collection and ingest into Weaviate (collection name must be PascalCase)",
                "consumes": [
                  "application/json"
                ]
              }
            },
            "/rag/weaviate/query": {
              "post": {
                "summary": "weaviate_query",
                "operationId": "post_rag_weaviate_query",
                "parameters": [
                  {
                    "name": "Authorization",
                    "in": "header",
                    "description": "Request parameter",
                    "required": false,
                    "type": "string"
                  },
                  {
                    "name": "body",
                    "in": "body",
                    "description": "request body parameter",
                    "required": true,
                    "schema": {
                      "$ref": "#/definitions/schema3"
                    }
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Rest Response",
                    "schema": {
                      "$ref": "#/definitions/schema2"
                    }
                  }
                },
                "description": "Accept natural language query from REST body or MCP arguments, embed with Ollama, retrieve top-K context passages from Weaviate",
                "consumes": [
                  "application/json"
                ]
              }
            },
            "/rag/weaviate/ingest/upload": {
              "post": {
                "summary": "weaviate_ingest_upload",
                "operationId": "post_rag_weaviate_ingest_upload",
                "parameters": [
                  {
                    "name": "collection",
                    "in": "formData",
                    "description": "Form Data Parameter",
                    "required": false,
                    "type": "string"
                  },
                  {
                    "name": "filename",
                    "in": "formData",
                    "description": "Form Data Parameter",
                    "required": false,
                    "type": "string"
                  },
                  {
                    "name": "file",
                    "in": "formData",
                    "description": "Form Data Parameter",
                    "required": false,
                    "type": "file"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Rest Response",
                    "schema": {
                      "$ref": "#/definitions/schema2"
                    }
                  }
                },
                "description": "Receive a binary file upload via multipart/form-data, extract text (PDF/DOCX/TXT), embed with Ollama and ingest into Weaviate.",
                "consumes": [
                  "multipart/form-data"
                ]
              }
            },
            "/rag/weaviate/query/generate": {
              "post": {
                "summary": "weaviate_query_generate",
                "operationId": "post_rag_weaviate_query_generate",
                "parameters": [
                  {
                    "name": "Authorization",
                    "in": "header",
                    "description": "Request parameter",
                    "required": false,
                    "type": "string"
                  },
                  {
                    "name": "body",
                    "in": "body",
                    "description": "request body parameter",
                    "required": true,
                    "schema": {
                      "$ref": "#/definitions/schema3"
                    }
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Rest Response",
                    "schema": {
                      "$ref": "#/definitions/schema2"
                    }
                  }
                },
                "description": "Full RAG with LLM generation: embed + hybrid search + llama3.1:8b answer",
                "consumes": [
                  "application/json"
                ]
              }
            },
            "/rag/weaviate/ingest/smart": {
              "post": {
                "summary": "weaviate_ingest_smart",
                "operationId": "post_rag_weaviate_ingest_smart",
                "parameters": [
                  {
                    "name": "collection",
                    "in": "formData",
                    "description": "Form Data Parameter",
                    "required": false,
                    "type": "string"
                  },
                  {
                    "name": "filename",
                    "in": "formData",
                    "description": "Form Data Parameter",
                    "required": false,
                    "type": "string"
                  },
                  {
                    "name": "file",
                    "in": "formData",
                    "description": "Form Data Parameter",
                    "required": false,
                    "type": "file"
                  },
                  {
                    "name": "interface_id",
                    "in": "formData",
                    "description": "Form Data Parameter",
                    "required": false,
                    "type": "string"
                  },
                  {
                    "name": "owner",
                    "in": "formData",
                    "description": "Form Data Parameter",
                    "required": false,
                    "type": "string"
                  },
                  {
                    "name": "document_type",
                    "in": "formData",
                    "description": "Form Data Parameter",
                    "required": false,
                    "type": "string"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Rest Response",
                    "schema": {
                      "type": "string"
                    }
                  }
                },
                "description": "Smart ingest: Docling extracts structured Markdown (preserves tables/headings), heading-strategy chunker splits on ##, every chunk inherits global metadata (interface_id, owner, document_type, source_file).",
                "consumes": [
                  "multipart/form-data"
                ]
              }
            }
          },
          "definitions": {
            "schema1": {
              "type": "object",
              "properties": {
                "collection": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string"
                    }
                  }
                },
                "documents": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string"
                    },
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string"
                        },
                        "properties": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "object",
                              "properties": {
                                "type": {
                                  "type": "string"
                                }
                              }
                            },
                            "text": {
                              "type": "object",
                              "properties": {
                                "type": {
                                  "type": "string"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema2": {
              "type": "object",
              "properties": {}
            },
            "schema3": {
              "type": "object",
              "properties": {
                "collection": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string"
                    }
                  }
                },
                "query": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string"
                    }
                  }
                },
                "topK": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    ],
    "flogoVersion": "2.26.3"
  }
